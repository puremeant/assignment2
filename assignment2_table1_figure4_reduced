# Convert model names into file-safe names.
def safe_model_name(model_name: str) -> str:
    return model_name.replace("+", "plus").replace("-", "_")

# Shorten long interaction predictor names for plotting.
def shorten_predictor_label(col: str) -> str:
    """
    Make interaction names shorter for plotting.

    Examples:
    mom1m_x_macro_dp   -> mom1mdp
    mvel1_x_macro_svar -> mvel1svar
    sic2_35            -> sic2_35
    """
    return col.replace("_x_macro_", "")

# Select model predictor columns by excluding identifiers, dates, and outcome variables.
def get_predictor_columns(df: pd.DataFrame) -> list[str]:
    non_predictors = {
        "permno",
        "yyyymm",
        "year",
        "ret",
        "rf",
        "excess_ret",
        "primaryexch",
        "sic2",
    }
    return [c for c in df.columns if c not in non_predictors]

# Check that the three OLS-3 predictors are available.
def check_ols3_columns(predictor_cols: list[str]) -> list[str]:
    missing = [c for c in OLS3_COLS if c not in predictor_cols]
    if missing:
        raise KeyError(f"Missing OLS-3 columns: {missing}")

    print(f"OLS-3+H columns: {OLS3_COLS}")
    return OLS3_COLS

# Optionally subsample rows for computational feasibility. (If MAX_ROWS = None, this is skipped.)
def sample_xy(X: pd.DataFrame, y: pd.Series, max_rows: int | None):
    if max_rows is None or len(X) <= max_rows:
        return X, y

    idx = X.sample(n=max_rows, random_state=RANDOM_STATE).index
    return X.loc[idx], y.loc[idx]

# Compute validation RMSE.
def rmse_score(y_true, y_pred) -> float:
    mse = mean_squared_error(y_true, y_pred)
    return np.sqrt(mse)

# Compute panel predictive R2 using zero excess return as the benchmark.
def r2_zero_benchmark(y_true, y_pred) -> float:
    """
    Panel R2 with zero-prediction benchmark:
    R2 = 1 - sum((y - yhat)^2) / sum(y^2)
    """
    y_true = np.asarray(y_true)
    y_pred = np.asarray(y_pred)

    denom = np.sum(y_true ** 2)
    if denom == 0:
        return np.nan

    return 1 - np.sum((y_true - y_pred) ** 2) / denom


