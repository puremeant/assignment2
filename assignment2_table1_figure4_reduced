# 4. Figure 4 predictor-level R2-VIP
# ============================================================

# Compute predictor-level R2-VIP by zeroing out each predictor one at a time.
def compute_r2_vip_for_model(
    fitted_model,
    X_fit: pd.DataFrame,
    y_fit: pd.Series,
    vip_predictor_cols: list[str],
    model_name: str,
    oos_year: int,
    best_idx: int,
) -> pd.DataFrame:
    """
    Predictor-level R2-VIP.

    For each input predictor j:
        VI_j = R2_original - R2_after_setting_predictor_j_to_zero

    The fitted model is held fixed. Only one predictor column is zeroed at a time.
    This function uses a NumPy array internally to avoid making a full DataFrame copy for every predictor.
    """
    X_vip, y_vip = sample_xy(X_fit, y_fit, MAX_VIP_ROWS)

    base_pred = fitted_model.predict(X_vip)
    base_r2 = r2_zero_benchmark(y_vip, base_pred)

    X_arr = X_vip.to_numpy(dtype=np.float64, copy=True)
    col_to_idx = {c: i for i, c in enumerate(X_vip.columns)}

    rows = []

    for j, pred_col in enumerate(vip_predictor_cols, start=1):
        if pred_col not in col_to_idx:
            continue

        col_idx = col_to_idx[pred_col]

        original_col = X_arr[:, col_idx].copy()
        X_arr[:, col_idx] = 0.0

        zero_pred = fitted_model.predict(X_arr)
        zero_r2 = r2_zero_benchmark(y_vip, zero_pred)

        X_arr[:, col_idx] = original_col

        vip = base_r2 - zero_r2

        rows.append({
            "model": model_name,
            "oos_year": oos_year,
            "best_candidate_index": best_idx,
            "predictor": pred_col,
            "plot_label": shorten_predictor_label(pred_col),
            "base_r2": base_r2,
            "r2_when_zero": zero_r2,
            "r2_vip": vip,
            "r2_vip_percent": 100 * vip,
            "n_vip_rows": len(X_vip),
        })

        if j % 100 == 0:
            print(f"{model_name} {oos_year}: VIP {j}/{len(vip_predictor_cols)}")

    return pd.DataFrame(rows)

# Average VIP across OOS-year refits and plot Figure 4.
def summarize_and_plot_figure4(vip_raw: pd.DataFrame) -> pd.DataFrame:
    vip_avg = (
        vip_raw
        .groupby(["model", "predictor", "plot_label"], as_index=False)
        .agg(
            r2_vip=("r2_vip", "mean"),
            r2_vip_percent=("r2_vip_percent", "mean"),
        )
    )

    vip_avg_path = RESULT_DIR / "figure4_vip_reduced_average.csv"
    vip_avg.to_csv(vip_avg_path, index=False)

    print("\nSaved Figure 4 average VIP:")
    print(vip_avg_path)

    top = (
        vip_avg.sort_values(["model", "r2_vip"], ascending=[True, False])
        .groupby("model")
        .head(TOP_N_FIG4)
        .copy()
    )

    fig, axes = plt.subplots(
        nrows=len(FIGURE4_MODELS),
        ncols=1,
        figsize=(10, 3.2 * len(FIGURE4_MODELS)),
        constrained_layout=True,
    )

    if len(FIGURE4_MODELS) == 1:
        axes = [axes]

    for ax, model_name in zip(axes, FIGURE4_MODELS):
        temp = top[top["model"] == model_name].sort_values("r2_vip_percent")

        ax.barh(temp["plot_label"], temp["r2_vip_percent"])
        ax.set_title(model_name)
        ax.set_xlabel("R²-VIP, percentage points")
        ax.set_ylabel("")

    fig.suptitle("Figure 4: Predictor-Level Variable Importance", fontsize=14)

    png_path = RESULT_DIR / "figure4_variable_importance_reduced.png"
    pdf_path = RESULT_DIR / "figure4_variable_importance_reduced.pdf"

    fig.savefig(png_path, dpi=300, bbox_inches="tight")
    fig.savefig(pdf_path, bbox_inches="tight")

    print("\nSaved Figure 4:")
    print(png_path)
    print(pdf_path)

    return vip_avg


