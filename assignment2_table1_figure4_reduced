# Execute the full Table 1 and Figure 4 pipeline.
def main():
    warnings.filterwarnings("ignore")

    if not DATA_2021.exists():
        raise FileNotFoundError(
            f"Missing file: {DATA_2021}\n"
            "Run assignment2_build_data.py first."
        )

    print("\nLoading data...")
    df = pd.read_parquet(DATA_2021)

    df["yyyymm"] = df["yyyymm"].astype(str)
    df["year"] = df["yyyymm"].str.slice(0, 4).astype(int)

    df = df[
        (df["year"] >= SAMPLE_START)
        & (df["year"] <= FINAL_OOS_YEAR)
    ].copy()

    df = df.dropna(subset=["excess_ret"])

    predictor_cols = get_predictor_columns(df)
    ols3_cols = check_ols3_columns(predictor_cols)
    periods = create_estimation_periods()

    print("\nData summary:")
    print(f"Rows: {len(df):,}")
    print(f"Period: {df['yyyymm'].min()} to {df['yyyymm'].max()}")
    print(f"Predictors: {len(predictor_cols):,}")
    print(f"Predictor-level VIP columns: {len(predictor_cols):,}")
    print(f"OOS period: {FIRST_OOS_YEAR}-{FINAL_OOS_YEAR}")

    all_predictions = []
    all_tuning = []
    all_vip = []

    for model_name in TABLE1_MODELS:
        pred, tuning, vip = run_one_model(
            df=df,
            model_name=model_name,
            predictor_cols=predictor_cols,
            ols3_cols=ols3_cols,
            periods=periods,
        )

        all_predictions.append(pred)
        all_tuning.append(tuning)

        pred_path = RESULT_DIR / f"predictions_{SAMPLE_PERIOD}_{safe_model_name(model_name)}.parquet"
        pred.to_parquet(pred_path, index=False)
        print(f"Saved predictions: {pred_path}")

        tuning_path_model = RESULT_DIR / f"tuning_choices_{SAMPLE_PERIOD}_{safe_model_name(model_name)}.csv"
        tuning.to_csv(tuning_path_model, index=False)
        print(f"Saved tuning choices: {tuning_path_model}")

        if not vip.empty:
            all_vip.append(vip)

            vip_path_model = RESULT_DIR / f"figure4_vip_{SAMPLE_PERIOD}_{safe_model_name(model_name)}.csv"
            vip.to_csv(vip_path_model, index=False)
            print(f"Saved model-level Figure 4 VIP: {vip_path_model}")

    predictions = pd.concat(all_predictions, ignore_index=True)
    tuning_choices = pd.concat(all_tuning, ignore_index=True)

    predictions_path = RESULT_DIR / f"predictions_{SAMPLE_PERIOD}_all_models.parquet"
    tuning_path = RESULT_DIR / f"tuning_choices_{SAMPLE_PERIOD}.csv"

    predictions.to_parquet(predictions_path, index=False)
    tuning_choices.to_csv(tuning_path, index=False)

    print("\nSaved combined predictions and tuning choices:")
    print(predictions_path)
    print(tuning_path)

    # ========================================================
    # Table 1
    # ========================================================

    results = []

    for model_name, g in predictions.groupby("model"):
        r2 = r2_zero_benchmark(g["excess_ret"], g["prediction"])
        mse = mean_squared_error(g["excess_ret"], g["prediction"])

        results.append({
            "sample_period": SAMPLE_PERIOD,
            "sample": "All",
            "model": model_name,
            "r2_oos_percent": 100 * r2,
            "mse": mse,
            "n_oos_obs": len(g),
            "oos_start": g["yyyymm"].min(),
            "oos_end": g["yyyymm"].max(),
        })

    table1_long = pd.DataFrame(results)

    table1_wide = (
        table1_long
        .pivot_table(
            index=["sample_period", "sample"],
            columns="model",
            values="r2_oos_percent",
        )
        .reset_index()
    )

    ordered_cols = [
        "sample_period",
        "sample",
        "OLS+H",
        "OLS-3+H",
        "PCR",
        "ENet+H",
        "RF",
        "NN2",
        "NN4",
    ]

    table1_wide = table1_wide[
        [c for c in ordered_cols if c in table1_wide.columns]
    ]

    table1_long_path = RESULT_DIR / "table1_reduced_2000_2021_long.csv"
    table1_wide_path = RESULT_DIR / "table1_reduced_2000_2021_wide.csv"

    table1_long.to_csv(table1_long_path, index=False)
    table1_wide.to_csv(table1_wide_path, index=False)

    print("\n" + "=" * 90)
    print("FINAL TABLE 1 REDUCED-SAMPLE RESULTS")
    print("=" * 90)
    print(table1_wide)

    print("\nSaved Table 1:")
    print(table1_long_path)
    print(table1_wide_path)

    # ========================================================
    # Figure 4
    # ========================================================

    if all_vip:
        vip_raw = pd.concat(all_vip, ignore_index=True)

        vip_raw_path = RESULT_DIR / "figure4_vip_reduced_raw.csv"
        vip_raw.to_csv(vip_raw_path, index=False)

        print("\nSaved Figure 4 raw VIP:")
        print(vip_raw_path)

        vip_avg = summarize_and_plot_figure4(vip_raw)

        print("\nTop 10 Figure 4 predictors by model:")
        print(
            vip_avg
