# Run one model across all OOS years and save predictions/VIP inputs.
def run_one_model(
    df: pd.DataFrame,
    model_name: str,
    predictor_cols: list[str],
    ols3_cols: list[str],
    periods: pd.DataFrame,
):
    print("\n" + "=" * 80)
    print(f"Running model: {model_name}")
    print("=" * 80)

    model_predictors = ols3_cols if model_name == "OLS-3+H" else predictor_cols

    all_predictions = []
    all_vip = []
    tuning_rows = []

    for _, row in periods.iterrows():
        oos_year = int(row["oos_year"])
        tr_start = int(row["training_start"])
        tr_end = int(row["training_end"])
        val_start = int(row["validation_start"])
        val_end = int(row["validation_end"])

        print(
            f"\nOOS {oos_year}: "
            f"train {tr_start}-{tr_end}, validation {val_start}-{val_end}"
        )

        train = df[(df["year"] >= tr_start) & (df["year"] <= tr_end)]
        val = df[(df["year"] >= val_start) & (df["year"] <= val_end)]
        oos = df[df["year"].eq(oos_year)]

        if len(train) == 0 or len(val) == 0 or len(oos) == 0:
            print(f"Skipping {oos_year}: insufficient data")
            continue

        X_train_full = train[model_predictors]
        y_train_full = train["excess_ret"]

        X_train, y_train = sample_xy(X_train_full, y_train_full, MAX_TRAIN_ROWS)

        X_val = val[model_predictors]
        y_val = val["excess_ret"]

        X_train_val_full = pd.concat(
            [train[model_predictors], val[model_predictors]],
            axis=0,
        )
        y_train_val_full = pd.concat(
            [train["excess_ret"], val["excess_ret"]],
            axis=0,
        )

        X_train_val, y_train_val = sample_xy(
            X_train_val_full,
            y_train_val_full,
            MAX_TRAIN_ROWS,
        )

        X_oos = oos[model_predictors]

        print(f"Train rows used for tuning: {len(X_train):,}")
        print(f"Validation rows: {len(X_val):,}")
        print(f"Train+validation rows used for final fit: {len(X_train_val):,}")
        print(f"OOS rows: {len(X_oos):,}")
        print(f"Predictors: {len(model_predictors):,}")

        best_template, best_rmse, best_idx = tune_model(
            model_name,
            X_train,
            y_train,
            X_val,
            y_val,
        )

        tuning_rows.append({
            "sample_period": SAMPLE_PERIOD,
            "model": model_name,
            "oos_year": oos_year,
            "best_candidate_index": best_idx,
            "validation_rmse": best_rmse,
            "train_start": tr_start,
            "train_end": tr_end,
            "validation_start": val_start,
            "validation_end": val_end,
        })

        final_model = clone(best_template)
        final_model.fit(X_train_val, y_train_val)

        pred = final_model.predict(X_oos)

        pred_df = oos[["permno", "yyyymm", "year", "excess_ret"]].copy()
        pred_df["model"] = model_name
        pred_df["prediction"] = pred
        pred_df["validation_rmse"] = best_rmse
        pred_df["best_candidate_index"] = best_idx

        all_predictions.append(pred_df)

        if model_name in FIGURE4_MODELS:
            print(f"Computing Figure 4 predictor-level R2-VIP for {model_name}, OOS {oos_year}...")

            vip_df = compute_r2_vip_for_model(
                fitted_model=final_model,
                X_fit=X_train_val,
                y_fit=y_train_val,
                vip_predictor_cols=model_predictors,
                model_name=model_name,
                oos_year=oos_year,
                best_idx=best_idx,
            )

            all_vip.append(vip_df)

    if not all_predictions:
        raise RuntimeError(f"No predictions generated for {model_name}")

    predictions = pd.concat(all_predictions, ignore_index=True)
    tuning = pd.DataFrame(tuning_rows)

    vip = pd.concat(all_vip, ignore_index=True) if all_vip else pd.DataFrame()

    return predictions, tuning, vip


