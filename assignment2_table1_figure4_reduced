# Build the hyperparameter candidate grid for each model.
def get_model_grid(model_name: str):
    """
    Validation-based model selection.

    OLS+H and OLS-3+H:
    Huber-loss linear models implemented using SGDRegressor(loss="huber") for computational feasibility.

    ENet+H:
    Huber loss with elastic-net penalty.

    RF:
    n_estimators=100 for reduced computation.

    NN:
    The rolling validation window is used for hyperparameter selection.
    """
    if model_name == "OLS+H":
        return [
            Pipeline([
                ("scaler", StandardScaler()),
                ("model", SGDRegressor(
                    loss="huber",
                    penalty=None,
                    epsilon=0.01,
                    learning_rate="optimal",
                    max_iter=500,
                    tol=1e-4,
                    random_state=RANDOM_STATE,
                )),
            ])
        ]

    if model_name == "OLS-3+H":
        return [
            Pipeline([
                ("scaler", StandardScaler()),
                ("model", SGDRegressor(
                    loss="huber",
                    penalty=None,
                    epsilon=0.01,
                    learning_rate="optimal",
                    max_iter=500,
                    tol=1e-4,
                    random_state=RANDOM_STATE,
                )),
            ])
        ]

    if model_name == "PCR":
        return [
            Pipeline([
                ("scaler", StandardScaler()),
                ("pca", PCA(n_components=k, random_state=RANDOM_STATE)),
                ("model", LinearRegression()),
            ])
            for k in [5, 10, 15, 30, 50]
        ]

    if model_name == "ENet+H":
        return [
            Pipeline([
                ("scaler", StandardScaler()),
                ("model", SGDRegressor(
                    loss="huber",
                    penalty="elasticnet",
                    alpha=alpha,
                    l1_ratio=l1_ratio,
                    epsilon=0.01,
                    learning_rate="optimal",
                    max_iter=500,
                    tol=1e-4,
                    random_state=RANDOM_STATE,
                )),
            ])
            for alpha in [1e-4, 1e-3, 1e-2]
            for l1_ratio in [0.25, 0.50, 0.75]
        ]

    if model_name == "RF":
        # return [
        #     RandomForestRegressor(
        #         n_estimators=300,
        #         max_features=mtry,
        #         max_depth=depth,
        #         min_samples_leaf=50,
        #         n_jobs=-1,
        #         random_state=RANDOM_STATE,
        #     )
        #     for mtry in [5, 10, 20, 30]
        #     for depth in [2, 3, 4, 5, 6]
        # ]

        return [
            RandomForestRegressor(
                n_estimators=300,
                max_features=1,
                max_depth=1,
                min_samples_leaf=1,
                n_jobs=-1,
                random_state=RANDOM_STATE,
            )
        ]

    if model_name == "NN2":
        return [
            Pipeline([
                ("scaler", StandardScaler()),
                ("model", MLPRegressor(
                    hidden_layer_sizes=(32, 16),
                    activation="relu",
                    solver="adam",
                    learning_rate_init=lr,
                    alpha=penalty,
                    batch_size=10000,
                    max_iter=100,
                    early_stopping=True,
                    n_iter_no_change=5,
                    validation_fraction=0.1,
                    random_state=RANDOM_STATE,
                )),
            ])
            for lr in [0.001, 0.01]
            for penalty in [1e-5, 1e-3]
        ]

    if model_name == "NN4":
        return [
            Pipeline([
                ("scaler", StandardScaler()),
                ("model", MLPRegressor(
                    hidden_layer_sizes=(32, 16, 8, 4),
                    activation="relu",
                    solver="adam",
                    learning_rate_init=lr,
                    alpha=penalty,
                    batch_size=10000,
                    max_iter=100,
                    early_stopping=True,
                    n_iter_no_change=5,
                    validation_fraction=0.1,
                    random_state=RANDOM_STATE,
                )),
            ])
            for lr in [0.001, 0.01]
            for penalty in [1e-5, 1e-3]
        ]

    raise ValueError(f"Unknown model name: {model_name}")

# Select the best hyperparameter candidate based on validation RMSE
def tune_model(model_name: str, X_train, y_train, X_val, y_val):
    candidates = get_model_grid(model_name)

    best_template = None
    best_rmse = np.inf
    best_idx = None

    for i, template in enumerate(candidates):
        model = clone(template)

        try:
            model.fit(X_train, y_train)
            pred_val = model.predict(X_val)
            val_rmse = rmse_score(y_val, pred_val)

            if val_rmse < best_rmse:
                best_rmse = val_rmse
                best_template = template
                best_idx = i

        except Exception as e:
            print(f"Candidate failed | model={model_name}, idx={i}, error={e}")

    if best_template is None:
        raise RuntimeError(f"All candidates failed for {model_name}")

    print(f"Best {model_name} candidate index: {best_idx}, validation RMSE: {best_rmse:.8f}")

    return best_template, best_rmse, best_idx


