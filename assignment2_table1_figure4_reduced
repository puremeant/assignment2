# Create expanding-window training and rolling-window validation periods.
def create_estimation_periods() -> pd.DataFrame:
    rows = []

    for oos_year in range(FIRST_OOS_YEAR, FINAL_OOS_YEAR + 1):
        validation_end = oos_year - 1
        validation_start = oos_year - VALIDATION_YEARS
        training_start = SAMPLE_START
        training_end = validation_start - 1

        rows.append({
            "oos_year": oos_year,
            "training_start": training_start,
            "training_end": training_end,
            "validation_start": validation_start,
            "validation_end": validation_end,
        })

    periods = pd.DataFrame(rows)

    print("\nEstimation periods:")
    print(periods)

    return periods


